{
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/preview", "destination": "/preview.html" },
    { "source": "/((?!privacy|preview).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
